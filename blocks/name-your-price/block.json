{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "fc-name-your-price/form",
  "version": "1.2.1",
  "title": "Name Your Price",
  "category": "widgets",
  "icon": "money-alt",
  "description": "A name-your-price form powered by FluentCart.",
  "keywords": ["donate", "donation", "pay what you want", "pricing", "payment", "fluentcart"],
  "textdomain": "fc-name-your-price",
  "supports": {
    "html": false
  },
  "attributes": {
    "min": {
      "type": "string",
      "default": "1"
    },
    "max": {
      "type": "string",
      "default": "10000"
    },
    "showPresets": {
      "type": "string",
      "default": "yes"
    },
    "allowCustom": {
      "type": "string",
      "default": "yes"
    },
    "presetAmounts": {
      "type": "string",
      "default": "5,10,25,50,100"
    },
    "buttonText": {
      "type": "string",
      "default": "Pay {amount}"
    },
    "defaultAmount": {
      "type": "string",
      "default": ""
    },
    "productTitle": {
      "type": "string",
      "default": "Donation"
    },
    "textAlign": {
      "type": "string",
      "default": ""
    },
    "formTitle": {
      "type": "string",
      "default": ""
    },
    "formDescription": {
      "type": "string",
      "default": ""
    },
    "subscriptionButtonText": {
      "type": "string",
      "default": "Pay {amount} per {frequency}"
    },
    "subscriptionMode": {
      "type": "string",
      "default": "off"
    },
    "billingInterval": {
      "type": "string",
      "default": "monthly"
    },
    "coverFees": {
      "type": "string",
      "default": "off"
    },
    "feePercentage": {
      "type": "string",
      "default": "2.9"
    },
    "feeFixed": {
      "type": "string",
      "default": "0.30"
    },
    "feeText": {
      "type": "string",
      "default": "Cover the {fee} transaction fee"
    }
  },
  "editorScript": "file:./build/index.js",
  "style": "file:../../assets/css/pricing-form.css",
  "render": "file:./render.php"
}
